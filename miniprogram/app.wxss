page {
  --color-primary: #16a05d;
  --color-primary-dark: #0e7a46;
  --color-primary-deep: #0d5136;
  --color-primary-soft: #eaf5ef;
  --color-primary-tint: #f4faf6;
  --color-success-soft: #e8f6ee;
  --color-accent-blue: #2f80ed;
  --color-warning: #f5a524;
  --color-danger: #d93025;
  --color-text: #1f2d26;
  --color-text-secondary: #52615a;
  --color-muted: #7a8580;
  --color-border: #e4ebe7;
  --color-bg: #f5f7f6;
  --color-card: #ffffff;
  --color-on-primary: #ffffff;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;

  min-height: 100%;
  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  background: transparent;
  padding: 0;
  line-height: 1.4;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.section {
  margin-bottom: 28rpx;
}

.card {
  background: var(--color-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 28rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.list-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.body-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text);
}

.subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-muted);
}

.muted-text {
  display: block;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.metric-value {
  display: block;
  color: var(--color-primary-dark);
  font-size: 64rpx;
  font-weight: 700;
}

.empty {
  padding: 40rpx 28rpx;
  text-align: center;
  color: var(--color-muted);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 80rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  color: var(--color-text);
  font-size: 28rpx;
  background: #ffffff;
}

.small-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  background: #ffffff;
  color: var(--color-text);
  font-size: 24rpx;
}

.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid rgba(217, 48, 37, 0.24);
  background: #ffffff;
  color: var(--color-danger);
  font-size: 24rpx;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.label {
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: 600;
}

.input,
.picker-value,
.textarea {
  width: 100%;
  min-height: 78rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: #ffffff;
  color: var(--color-text);
  font-size: 28rpx;
}

.textarea {
  min-height: 144rpx;
  line-height: 1.5;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 116rpx;
}

.loading-state {
  padding: 32rpx 28rpx;
  text-align: center;
  color: var(--color-muted);
  font-size: 26rpx;
}
