.detail-page{padding-bottom:64rpx}.detail-cover{width:100%;height:360rpx;border-radius:var(--radius-md);background:var(--color-primary-soft)}.detail-head{padding:26rpx 0}.detail-title-line{display:flex;align-items:center;gap:12rpx}.recommend-mark{padding:5rpx 12rpx;border-radius:var(--radius-sm);background:var(--color-success-soft);color:var(--color-primary-dark);font-size:21rpx;font-weight:700}.tag-line{display:flex;flex-wrap:wrap;gap:10rpx;margin-top:18rpx}.tag{padding:7rpx 14rpx;border:1rpx solid rgba(22,160,93,.18);border-radius:var(--radius-sm);background:var(--color-primary-tint);color:var(--color-primary-dark);font-size:22rpx}.portion-bar{display:flex;align-items:center;justify-content:space-between;gap:20rpx;padding:24rpx 0;border-top:1rpx solid var(--color-border)}.portion-copy{flex:1;min-width:0}.stepper{display:grid;flex:0 0 224rpx;grid-template-columns:64rpx 96rpx 64rpx;align-items:center;width:224rpx;height:64rpx;overflow:hidden;border:1rpx solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-card)}.stepper-button{display:flex;align-items:center;justify-content:center;width:64rpx;height:64rpx;color:var(--color-primary-dark);font-size:34rpx;font-weight:600}.stepper-button:first-child{border-right:1rpx solid var(--color-border)}.stepper-button:last-child{border-left:1rpx solid var(--color-border)}.stepper-button-hover{background:var(--color-primary-soft)}.stepper-value{display:flex;align-items:center;justify-content:center;height:64rpx;text-align:center;white-space:nowrap;font-size:25rpx;font-weight:700}.nutrition-panel{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));padding:28rpx 10rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary)}.nutrition-panel view{text-align:center;border-right:1rpx solid rgba(255,255,255,.18)}.nutrition-panel view:last-child{border-right:0}.nutrition-value{display:block;font-size:31rpx;font-weight:800}.nutrition-label{display:block;margin-top:7rpx;color:rgba(255,255,255,.72);font-size:19rpx}.detail-section{padding:32rpx 0;border-bottom:1rpx solid var(--color-border)}.section-heading{display:flex;align-items:center;justify-content:space-between;margin-bottom:18rpx}.ingredient-row{display:flex;align-items:center;justify-content:space-between;min-height:66rpx;font-size:27rpx}.ingredient-amount{color:var(--color-muted)}.step-row{display:grid;grid-template-columns:48rpx minmax(0,1fr);gap:14rpx;margin-bottom:22rpx}.step-number{display:flex;align-items:center;justify-content:center;width:42rpx;height:42rpx;border-radius:50%;background:var(--color-success-soft);color:var(--color-primary-dark);font-size:22rpx;font-weight:800}.step-text{font-size:27rpx;line-height:1.6}.meal-actions{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14rpx;padding-top:32rpx}.meal-action-title{grid-column:1/-1;margin-bottom:4rpx}.meal-button{display:flex;align-items:center;justify-content:center;min-height:78rpx;border-radius:var(--radius-md);background:var(--color-primary);color:var(--color-on-primary);font-size:27rpx;font-weight:700}.meal-button[disabled]{opacity:.58}.empty-title{display:block;margin-bottom:10rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry-button{margin-top:22rpx}
