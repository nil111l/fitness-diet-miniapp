.recipe-page{padding-bottom:72rpx}.recipe-head{display:flex;align-items:flex-start;justify-content:space-between;gap:20rpx;margin-bottom:24rpx}.plan-entry{display:flex;align-items:center;justify-content:center;flex:0 0 150rpx;min-height:64rpx;border:1rpx solid rgba(22,160,93,.24);border-radius:var(--radius-md);background:var(--color-card);color:var(--color-primary-dark);font-size:24rpx;font-weight:700}.filter-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12rpx;margin-bottom:24rpx}.filter-control{display:flex;align-items:center;justify-content:center;min-height:68rpx;padding:0 10rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card);color:var(--color-text);font-size:23rpx;text-align:center}.recipe-list{display:flex;flex-direction:column;gap:18rpx}.recipe-card{display:grid;grid-template-columns:190rpx minmax(0,1fr);min-height:224rpx;overflow:hidden;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.recipe-cover{width:190rpx;height:100%}.recipe-cover-fallback{display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--color-primary-soft);color:var(--color-primary-dark)}.fallback-kcal{font-size:42rpx;font-weight:800}.fallback-unit{margin-top:4rpx;font-size:21rpx}.recipe-content{min-width:0;padding:22rpx}.recipe-title-line{display:flex;align-items:center;gap:10rpx}.recipe-title-line .list-title{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.recommend-mark{flex:none;padding:4rpx 10rpx;border-radius:var(--radius-sm);background:var(--color-success-soft);color:var(--color-primary-dark);font-size:20rpx;font-weight:700}.recipe-intro{margin-top:8rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.nutrition-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:5rpx 12rpx;margin-top:13rpx;color:var(--color-text-secondary);font-size:21rpx}.recipe-scope{display:block;margin-top:12rpx;color:var(--color-primary-dark);font-size:21rpx}.empty-title{display:block;margin-bottom:10rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.empty-action{margin-top:22rpx}
