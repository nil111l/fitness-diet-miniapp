.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.efficiency-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14rpx}.efficiency-card{min-height:108rpx;padding:22rpx;border:1rpx solid rgba(22,160,93,.14);border-radius:var(--radius-md);background:rgba(22,160,93,.05)}.efficiency-title{display:block;color:var(--color-text);font-size:27rpx;font-weight:700}.efficiency-desc{display:block;margin-top:7rpx;color:var(--color-muted);font-size:21rpx}

.record-card {
  min-height: 132rpx;
}

.record-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.record-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-muted);
  line-height: 1.5;
}

.recipe-tools {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.recipe-tool {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 128rpx;
  padding: 22rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-deep);
  color: #ffffff;
}

.recipe-tool-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
}

.recipe-tool-desc {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 21rpx;
  line-height: 1.45;
}

.recipe-tool-arrow {
  margin-left: 10rpx;
  color: rgba(255, 255, 255, 0.75);
  font-size: 38rpx;
}

.training-head{display:flex;align-items:baseline;justify-content:space-between;gap:16rpx;margin-bottom:14rpx}.training-caption{color:var(--color-muted);font-size:21rpx}.training-menu{overflow:hidden;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.training-row{display:flex;min-height:102rpx;align-items:center;justify-content:space-between;gap:18rpx;padding:18rpx 22rpx;border-bottom:1rpx solid var(--color-border)}.training-row:last-child{border-bottom:0}.today-training-row{background:var(--color-primary-tint)}.training-title,.training-desc{display:block}.training-title{color:var(--color-text);font-size:27rpx;font-weight:700}.training-desc{margin-top:6rpx;color:var(--color-muted);font-size:21rpx}.training-arrow{flex:none;color:var(--color-muted);font-size:38rpx}
