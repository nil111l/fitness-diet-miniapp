.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.label {
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: 600;
}

.input,
.picker-value,
.textarea {
  width: 100%;
  min-height: 78rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: #ffffff;
  color: var(--color-text);
  font-size: 28rpx;
}

.textarea {
  min-height: 144rpx;
  line-height: 1.5;
}

.submit-button {
  margin-top: 12rpx;
}
