.checkin-card .metric-value {
  margin-top: 12rpx;
}

.checkin-row {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
  color: var(--color-muted);
  font-size: 24rpx;
}

.tag.active {
  border-color: rgba(22, 160, 93, 0.24);
  background: rgba(22, 160, 93, 0.08);
  color: var(--color-primary-dark);
}

.chart-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.bar-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bar-row {
  display: grid;
  grid-template-columns: 72rpx 1fr 96rpx;
  align-items: center;
  gap: 12rpx;
}

.bar-date,
.bar-value {
  color: var(--color-muted);
  font-size: 24rpx;
}

.bar-value {
  text-align: right;
}

.bar-track {
  height: 18rpx;
  border-radius: 18rpx;
  background: var(--color-border);
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  min-width: 0;
  border-radius: 18rpx;
}

.bar-fill.weight {
  background: var(--color-primary);
}

.bar-fill.calorie {
  background: var(--color-accent-blue);
}

.bar-fill.exercise {
  background: var(--color-warning);
}

.macro-share {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.empty-action {
  margin-top: 24rpx;
}

.insight-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16rpx}.insight-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14rpx}.insight-entry{min-height:120rpx;padding:22rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.entry-title,.entry-desc{display:block}.entry-title{color:var(--color-text);font-size:27rpx;font-weight:700}.entry-desc{margin-top:7rpx;color:var(--color-muted);font-size:21rpx;line-height:1.4}.article-entry{display:flex;min-height:94rpx;align-items:center;justify-content:space-between;gap:18rpx;margin-top:14rpx;padding:18rpx 22rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary)}.article-entry .entry-title{color:var(--color-on-primary)}.article-entry .entry-desc{color:rgba(255,255,255,.68)}.entry-arrow{font-size:38rpx}
