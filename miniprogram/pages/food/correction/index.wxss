.food-panel{padding:26rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary)}.food-name{display:block;font-size:34rpx;font-weight:800}.nutrition-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));margin-top:22rpx}.nutrition-grid>view{text-align:center;border-right:1rpx solid rgba(255,255,255,.18)}.nutrition-grid>view:last-child{border-right:0}.nutrition-grid text{display:block}.nutrition-grid text:first-child{font-size:28rpx;font-weight:800}.nutrition-grid text:last-child{margin-top:5rpx;color:rgba(255,255,255,.65);font-size:18rpx}.per-label{display:block;margin-top:18rpx;color:rgba(255,255,255,.62);font-size:20rpx}.field-count{display:block;margin-top:6rpx;color:var(--color-muted);font-size:20rpx;text-align:right}.submit-button{display:flex;align-items:center;justify-content:center}.history-link{padding:24rpx;color:var(--color-primary-dark);font-size:24rpx;text-align:center}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{width:220rpx;margin:24rpx auto 0}
