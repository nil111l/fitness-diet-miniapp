.correction-list{display:flex;flex-direction:column;gap:16rpx}.correction-card{padding:24rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.card-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16rpx}.food-name,.type-text{display:block}.food-name{color:var(--color-text);font-size:29rpx;font-weight:700}.type-text{margin-top:5rpx;color:var(--color-muted);font-size:21rpx}.status{flex:none;color:var(--color-muted);font-size:21rpx}.status-resolved{color:var(--color-primary-dark)}.status-processing{color:var(--color-accent-blue)}.status-rejected{color:var(--color-danger)}.description{display:block;margin-top:18rpx;color:var(--color-text-secondary);font-size:25rpx;line-height:1.6}.suggested{display:block;margin-top:10rpx;color:var(--color-primary-dark);font-size:23rpx}.reply{margin-top:18rpx;padding:18rpx;border-radius:var(--radius-sm);background:var(--color-primary-tint);color:var(--color-text-secondary);font-size:23rpx;line-height:1.55}.reply-label{display:block;margin-bottom:6rpx;color:var(--color-primary-dark);font-weight:700}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{width:220rpx;margin:24rpx auto 0}
