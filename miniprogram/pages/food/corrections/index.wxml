<view class="page"><view class="section"><text class="title">我的纠错记录</text><text class="subtitle">查看平台食材纠错的处理进度。</text></view><view class="correction-list" wx:if="{{records.length}}"><view class="correction-card" wx:for="{{records}}" wx:key="_id"><view class="card-head"><view><text class="food-name">{{item.food_name}}</text><text class="type-text">{{item.correction_type_text}}</text></view><text class="status status-{{item.status}}">{{item.status_text}}</text></view><text class="description">{{item.description}}</text><text wx:if="{{item.suggested_value}}" class="suggested">建议：{{item.suggested_value}}</text><view wx:if="{{item.admin_note}}" class="reply"><text class="reply-label">处理说明</text><text>{{item.admin_note}}</text></view></view></view><view class="card empty" wx:elif="{{!loading}}"><text class="empty-title">{{loadFailed ? '纠错记录加载失败' : '还没有提交过纠错'}}</text><text class="muted-text">{{loadFailed ? '请检查网络后重新加载。' : '在平台食材列表中点击“纠错”即可提交。'}}</text><view wx:if="{{loadFailed}}" class="secondary-button retry" role="button" bindtap="loadRecords">重新加载</view></view><view class="loading-state" wx:if="{{loading}}">正在加载...</view></view>
