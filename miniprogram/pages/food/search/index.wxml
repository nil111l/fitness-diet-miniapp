<view class="page food-search-page">
  <view class="section">
    <text class="title">食物搜索</text>
    <text class="subtitle">搜索平台食材或你的自定义食物。</text>
  </view>

  <view class="section search-bar">
    <input class="search-input" placeholder="输入食物名称" value="{{keyword}}" bindinput="handleKeyword" confirm-type="search" bindconfirm="searchFoods" />
    <button class="search-button" bindtap="searchFoods">搜索</button>
  </view>

  <view class="section actions">
    <picker class="action-picker" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="handleCategory">
      <view class="filter-button">{{categories[categoryIndex].name}}</view>
    </picker>
    <button class="filter-button" bindtap="goCustom">新建食物</button>
    <button class="filter-button" bindtap="goMyFoods">我的食物</button>
  </view>

  <view class="section list">
    <view wx:if="{{!foods.length}}" class="card empty">暂无食物</view>
    <block wx:for="{{foods}}" wx:key="_id">
      <view class="card food-card" data-food="{{item}}" bindtap="addFood">
        <view class="food-main">
          <text class="food-name">{{item.name}}</text>
          <text class="food-desc">
            <text wx:if="{{item.source === 'custom'}}">自定义</text>
            <text wx:else>平台</text>
            <text> · {{item.calorie_per_100g}} kcal/100g</text>
          </text>
        </view>
        <text class="food-add">添加</text>
      </view>
    </block>
  </view>
</view>
