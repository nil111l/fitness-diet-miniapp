<view class="page">
  <view class="section"><text class="title">目标进度</text><text class="subtitle">把当前目标与本周记录放在一起查看。</text></view>
  <view class="loading-state" wx:if="{{loading}}">正在加载目标...</view>
  <view class="card empty" wx:elif="{{loadFailed}}"><text class="empty-title">目标进度加载失败</text><view class="secondary-button retry" role="button" bindtap="loadProgress">重新加载</view></view>
  <view class="card empty" wx:elif="{{progress && !progress.has_goal}}"><text class="empty-title">还没有设置目标</text><text class="muted-text">设置目标后可查看热量、营养和体重方向。</text><view class="primary-button retry" role="button" bindtap="goGoal">设置目标</view></view>
  <block wx:elif="{{progress}}">
    <view class="section goal-panel"><text class="goal-label">{{goalText}}</text><text class="goal-calorie">{{progress.goal.daily_calorie_target}} <text class="goal-unit">kcal / 天</text></text><view class="macro-line"><text>蛋白质 {{progress.goal.macro_targets.protein_g}}g</text><text>碳水 {{progress.goal.macro_targets.carb_g}}g</text><text>脂肪 {{progress.goal.macro_targets.fat_g}}g</text></view></view>
    <view class="section card weight-card"><view><text class="muted-text">当前体重</text><text class="weight-value">{{progress.current_weight_kg || '--'}} kg</text></view><view class="weight-divider"></view><view><text class="muted-text">目标体重</text><text class="weight-value">{{progress.target_weight_kg || '--'}} kg</text></view></view>
    <view class="section card"><text class="section-title">本周执行</text><view class="week-grid"><view><text class="week-value">{{progress.week.average_calorie}}</text><text class="week-label">平均摄入</text></view><view><text class="week-value">{{progress.week.diet_record_days}}</text><text class="week-label">饮食天数</text></view><view><text class="week-value">{{progress.week.training_count}}</text><text class="week-label">训练次数</text></view></view></view>
    <view class="section action-row"><view class="secondary-button action" role="button" bindtap="goGoal">调整目标</view><view class="primary-button action" role="button" bindtap="goRecord">继续记录</view></view>
  </block>
</view>
