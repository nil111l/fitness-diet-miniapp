.goal-panel{padding:28rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary)}.goal-label,.goal-calorie{display:block}.goal-label{color:rgba(255,255,255,.7);font-size:23rpx}.goal-calorie{margin-top:10rpx;font-size:52rpx;font-weight:800}.goal-unit{font-size:22rpx;font-weight:400}.macro-line{display:flex;flex-wrap:wrap;gap:10rpx 22rpx;margin-top:20rpx;color:rgba(255,255,255,.75);font-size:21rpx}.weight-card{display:grid;grid-template-columns:1fr 1rpx 1fr;align-items:center;text-align:center}.weight-divider{width:1rpx;height:70rpx;background:var(--color-border)}.weight-value{display:block;margin-top:8rpx;color:var(--color-text);font-size:32rpx;font-weight:800}.week-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));margin-top:22rpx}.week-grid>view{text-align:center}.week-value,.week-label{display:block}.week-value{color:var(--color-text);font-size:34rpx;font-weight:800}.week-label{margin-top:6rpx;color:var(--color-muted);font-size:20rpx}.action-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14rpx}.action{display:flex;align-items:center;justify-content:center}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{display:flex;width:220rpx;margin:24rpx auto 0;align-items:center;justify-content:center}
