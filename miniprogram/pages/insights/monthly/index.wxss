.month-switch{display:grid;grid-template-columns:74rpx 1fr 74rpx;align-items:center}.month-button{display:flex;width:74rpx;height:60rpx;align-items:center;justify-content:center;border:1rpx solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-card);color:var(--color-text);font-size:36rpx}.month-button-disabled{color:#c5ccc8}.month-label{text-align:center;color:var(--color-text);font-size:30rpx;font-weight:700}.summary-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14rpx}.metric-card{min-height:150rpx;padding:24rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.metric-label,.metric-number,.metric-unit{display:block}.metric-label{color:var(--color-muted);font-size:22rpx}.metric-number{margin-top:10rpx;color:var(--color-text);font-size:44rpx;font-weight:800}.small-number{font-size:38rpx}.metric-unit{margin-top:4rpx;color:var(--color-muted);font-size:20rpx}.macro-card .muted-text{display:block;margin-top:6rpx}.macro-row{margin-top:24rpx}.macro-head{display:flex;justify-content:space-between;color:var(--color-text-secondary);font-size:23rpx}.track{height:12rpx;margin-top:9rpx;overflow:hidden;border-radius:6rpx;background:var(--color-border)}.fill{height:100%;border-radius:6rpx}.protein{background:var(--color-primary)}.carb{background:var(--color-accent-blue)}.fat{background:var(--color-warning)}.advice-panel{padding:26rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary)}.advice-label,.advice-text{display:block}.advice-label{color:rgba(255,255,255,.7);font-size:22rpx}.advice-text{margin-top:10rpx;font-size:27rpx;line-height:1.6}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{display:flex;width:220rpx;margin:24rpx auto 0;align-items:center;justify-content:center}
