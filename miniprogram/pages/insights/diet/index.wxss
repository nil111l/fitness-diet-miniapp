.insight-list{display:flex;flex-direction:column;gap:16rpx}.insight-card{padding:26rpx;border:1rpx solid var(--color-border);border-left:8rpx solid var(--color-primary);border-radius:var(--radius-md);background:var(--color-card)}.insight-attention{border-left-color:var(--color-warning)}.insight-reminder{border-left-color:var(--color-accent-blue)}.insight-title,.insight-message{display:block}.insight-title{color:var(--color-text);font-size:29rpx;font-weight:700}.insight-message{margin-top:10rpx;color:var(--color-text-secondary);font-size:25rpx;line-height:1.65}.disclaimer{margin-top:28rpx;padding:20rpx;border-radius:var(--radius-sm);background:var(--color-primary-tint);color:var(--color-muted);font-size:21rpx;line-height:1.55}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{display:flex;width:220rpx;margin:24rpx auto 0;align-items:center;justify-content:center}
