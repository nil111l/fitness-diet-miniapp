<view class="page">
  <view class="section"><text class="title">本周总结</text><text class="subtitle" wx:if="{{summary}}">{{summary.period.start}} 至 {{summary.period.end}} · 免费查看</text></view>
  <view class="loading-state" wx:if="{{loading}}">正在汇总本周记录...</view>
  <view class="card empty" wx:elif="{{loadFailed}}"><text class="empty-title">本周总结加载失败</text><text class="muted-text">请检查网络后重试。</text><view class="secondary-button retry" role="button" bindtap="loadSummary">重新加载</view></view>
  <view class="card empty" wx:elif="{{summary && !summary.has_data}}"><text class="empty-title">本周还没有记录</text><text class="muted-text">从一餐、一次训练或一次体重开始，数据会自动进入总结。</text><view class="primary-button retry" role="button" bindtap="goRecord">去记录</view></view>
  <block wx:elif="{{summary}}">
    <view class="summary-grid section">
      <view class="metric-card"><text class="metric-label">平均摄入</text><text class="metric-number">{{summary.average_calorie}}</text><text class="metric-unit">kcal / 记录日</text></view>
      <view class="metric-card"><text class="metric-label">训练次数</text><text class="metric-number">{{summary.training_count}}</text><text class="metric-unit">次</text></view>
      <view class="metric-card"><text class="metric-label">饮食记录</text><text class="metric-number">{{summary.diet_record_days}}</text><text class="metric-unit">天</text></view>
      <view class="metric-card"><text class="metric-label">运动记录</text><text class="metric-number">{{summary.exercise_record_days}}</text><text class="metric-unit">天</text></view>
    </view>
    <view class="section card detail-card">
      <view class="detail-row"><text class="detail-label">体重变化</text><text class="detail-value" wx:if="{{summary.weight.change !== null}}">{{summary.weight.change > 0 ? '+' : ''}}{{summary.weight.change}} kg</text><text class="detail-value muted-text" wx:else>至少记录两次后显示</text></view>
      <view class="detail-row"><text class="detail-label">最常吃食物</text><text class="detail-value" wx:if="{{summary.most_frequent_food}}">{{summary.most_frequent_food.name}} · {{summary.most_frequent_food.count}} 次</text><text class="detail-value muted-text" wx:else>暂无饮食记录</text></view>
    </view>
    <view class="section advice-panel"><text class="advice-label">本周建议</text><text class="advice-text">{{summary.suggestion}}</text></view>
    <view class="section primary-button" role="button" bindtap="goDiet">继续记录饮食</view>
  </block>
</view>
