.summary-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14rpx}.metric-card{min-height:150rpx;padding:24rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.metric-label,.metric-number,.metric-unit{display:block}.metric-label{color:var(--color-muted);font-size:22rpx}.metric-number{margin-top:10rpx;color:var(--color-text);font-size:44rpx;font-weight:800}.metric-unit{margin-top:4rpx;color:var(--color-muted);font-size:20rpx}.detail-card{padding:0 24rpx}.detail-row{display:flex;min-height:92rpx;align-items:center;justify-content:space-between;gap:20rpx;border-bottom:1rpx solid var(--color-border)}.detail-row:last-child{border-bottom:0}.detail-label{color:var(--color-text-secondary);font-size:24rpx}.detail-value{max-width:65%;color:var(--color-text);font-size:25rpx;font-weight:700;text-align:right}.advice-panel{padding:26rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary)}.advice-label,.advice-text{display:block}.advice-label{color:rgba(255,255,255,.7);font-size:22rpx}.advice-text{margin-top:10rpx;font-size:27rpx;line-height:1.6}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{display:flex;width:220rpx;margin:24rpx auto 0;align-items:center;justify-content:center}
