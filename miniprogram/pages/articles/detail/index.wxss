.article-hero{width:100%;height:300rpx;border-radius:var(--radius-md);background:var(--color-primary-soft)}.hero-fallback{display:flex;align-items:flex-end;padding:28rpx;background:var(--color-primary-deep);color:var(--color-on-primary);font-size:34rpx;font-weight:800}.article-head{padding:26rpx 0;border-bottom:1rpx solid var(--color-border)}.article-category{display:block;margin-bottom:12rpx;color:var(--color-primary-dark);font-size:22rpx;font-weight:700}.article-head .subtitle{display:block;margin-top:12rpx;line-height:1.6}.article-body{padding:10rpx 0 30rpx}.paragraph{display:block;margin-top:24rpx;color:var(--color-text-secondary);font-size:28rpx;line-height:1.85}.reference-note{padding:20rpx;border-radius:var(--radius-sm);background:var(--color-primary-tint);color:var(--color-muted);font-size:21rpx;line-height:1.5}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{width:220rpx;margin:24rpx auto 0}
