.search-row{display:flex;gap:12rpx}.search-input{flex:1;min-width:0}.search-button{display:flex;flex:0 0 108rpx;width:108rpx;align-items:center;justify-content:center;border-radius:var(--radius-md);background:var(--color-primary);color:var(--color-on-primary);font-size:24rpx;font-weight:700}.category-scroll{width:100%;margin:20rpx 0 24rpx;white-space:nowrap}.category-row{display:inline-flex;gap:10rpx;padding-right:28rpx}.category-chip{display:flex;height:58rpx;align-items:center;padding:0 22rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-card);color:var(--color-text-secondary);font-size:23rpx}.category-chip-active{border-color:rgba(22,160,93,.28);background:var(--color-primary-soft);color:var(--color-primary-dark);font-weight:700}.article-list{display:flex;flex-direction:column;gap:16rpx}.article-card{display:flex;min-width:0;gap:18rpx;padding:18rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.article-cover{flex:0 0 148rpx;width:148rpx;height:136rpx;border-radius:var(--radius-sm);background:var(--color-primary-soft)}.cover-fallback{display:flex;align-items:center;justify-content:center;padding:12rpx;color:var(--color-primary-dark);font-size:23rpx;font-weight:700;text-align:center}.article-copy{flex:1;min-width:0}.article-meta{display:flex;gap:10rpx;color:var(--color-primary-dark);font-size:20rpx}.recommend{padding:2rpx 8rpx;border-radius:var(--radius-sm);background:var(--color-primary-soft)}.article-title{display:block;overflow:hidden;margin-top:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.article-summary{display:-webkit-box;overflow:hidden;margin-top:8rpx;color:var(--color-muted);font-size:22rpx;line-height:1.5;-webkit-box-orient:vertical;-webkit-line-clamp:2}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.clear-button{display:flex;width:200rpx;margin:24rpx auto 0;align-items:center;justify-content:center}
