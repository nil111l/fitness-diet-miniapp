.plan-head{margin-bottom:28rpx}.plan-form{display:flex;flex-direction:column;gap:20rpx;padding-bottom:30rpx;border-bottom:1rpx solid var(--color-border)}.calorie-fields{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16rpx}.plan-result{display:flex;flex-direction:column;gap:16rpx;padding-top:28rpx}.plan-total{padding:28rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary)}.plan-total-label{display:block;color:rgba(255,255,255,.7);font-size:23rpx}.plan-total-value{display:block;margin-top:5rpx;font-size:52rpx;font-weight:800}.plan-total-value text{font-size:22rpx;font-weight:500}.plan-macros{display:flex;justify-content:space-between;gap:12rpx;margin-top:20rpx;color:rgba(255,255,255,.78);font-size:21rpx}.meal-card{display:flex;align-items:center;gap:16rpx;padding:24rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.meal-card-main{flex:1;min-width:0}.meal-title-line{display:flex;align-items:center;justify-content:space-between;gap:12rpx;margin-bottom:8rpx}.meal-name{flex:none;color:var(--color-primary-dark);font-size:23rpx;font-weight:800}.meal-kcal{flex:none;color:var(--color-muted);font-size:22rpx;white-space:nowrap}.recipe-name,.meal-card-main .muted-text{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.replace-button{display:flex;flex:0 0 112rpx;align-items:center;justify-content:center;width:112rpx;height:64rpx;border:1rpx solid rgba(22,160,93,.24);border-radius:var(--radius-md);background:var(--color-card);color:var(--color-primary-dark);font-size:23rpx;font-weight:700}.replace-button-hover{background:var(--color-primary-soft)}.add-plan-button{margin-top:10rpx}.empty{margin-top:28rpx}.empty-title{display:block;margin-bottom:10rpx;color:var(--color-text);font-size:28rpx;font-weight:700}
