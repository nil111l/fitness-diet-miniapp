.reminder-page{padding-bottom:64rpx}.notice-card{border-color:rgba(245,165,36,.28);background:var(--color-card)}.notice-card .muted-text{margin-top:10rpx}.reminder-card{display:flex;flex-direction:column;gap:24rpx}.reminder-head,.reminder-foot{display:flex;align-items:center;justify-content:space-between;gap:20rpx}.reminder-copy{min-width:0}.reminder-copy .muted-text{margin-top:8rpx}.time-picker{display:flex;align-items:center;justify-content:center;min-width:148rpx;height:68rpx;padding:0 20rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card);color:var(--color-text);font-size:28rpx;font-weight:600}.status-text{max-width:360rpx;color:var(--color-muted);font-size:23rpx;text-align:right;line-height:1.4}
