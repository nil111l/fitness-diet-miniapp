.page-head,.template-head,.template-actions{display:flex;align-items:center;justify-content:space-between;gap:20rpx}.page-head{align-items:flex-start}.template-card{display:flex;flex-direction:column;gap:20rpx}.type-text,.food-names{display:block;margin-top:8rpx;color:var(--color-muted);font-size:24rpx;line-height:1.5}.food-names{margin-top:0}.meal-picker{display:flex;align-items:center;min-height:64rpx;padding:0 18rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);font-size:24rpx}.add-button{border-color:rgba(22,160,93,.28);color:var(--color-primary-dark)}.empty .muted-text{margin-top:10rpx}.empty-action{margin-top:24rpx}
