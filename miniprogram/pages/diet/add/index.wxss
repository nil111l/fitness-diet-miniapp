.food-card{display:flex;align-items:center;justify-content:space-between;gap:16rpx}.food-name{display:block;font-size:32rpx;font-weight:700}.food-desc{display:block;margin-top:8rpx;color:var(--color-muted);font-size:24rpx;line-height:1.5}.small-button{min-width:120rpx;height:64rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);font-size:24rpx;color:var(--color-text);background:#fff}.form-card,.field{display:flex;flex-direction:column;gap:20rpx}.label{font-size:26rpx;font-weight:600}.input,.picker-value{height:78rpx;padding:0 20rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:#fff;font-size:28rpx}.favorite-field{display:flex;align-items:center;justify-content:space-between;gap:24rpx;padding-top:8rpx}.field-hint{display:block;margin-top:6rpx;color:var(--color-muted);font-size:22rpx}.result-title{display:block;font-size:30rpx;font-weight:700}.result-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20rpx;margin-top:20rpx}
