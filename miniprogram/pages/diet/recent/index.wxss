.meal-selector{display:grid;grid-template-columns:100rpx 1fr;align-items:center;gap:20rpx}.picker-value{display:flex;align-items:center;min-height:72rpx;padding:0 20rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md)}.recent-row{display:flex;align-items:center;justify-content:space-between;gap:20rpx;min-height:116rpx}.recent-row .muted-text{margin-top:8rpx}.add-text{flex:0 0 auto;color:var(--color-primary-dark);font-size:26rpx;font-weight:600}.empty .muted-text{margin-top:10rpx}.empty-action{margin-top:24rpx}
