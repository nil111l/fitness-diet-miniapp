.diet-detail-page {
  padding-bottom: 64rpx;
}

.page-head {
  margin-bottom: 24rpx;
}

.page-caption {
  display: block;
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.5;
  white-space: nowrap;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.quick-action {
  display: flex;
  min-width: 0;
  min-height: 98rpx;
  flex-direction: column;
  justify-content: center;
  padding: 18rpx 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-card);
}

.quick-action-hover,
.action-hover {
  background: var(--color-primary-tint);
}

.quick-action-title {
  color: var(--color-text);
  font-size: 26rpx;
  font-weight: 700;
}

.quick-action-desc {
  display: block;
  overflow: hidden;
  margin-top: 5rpx;
  color: var(--color-muted);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-panel {
  margin-bottom: 28rpx;
  padding: 26rpx 28rpx 28rpx;
  border-radius: var(--radius-md);
  background: var(--color-primary-deep);
  color: var(--color-on-primary);
}

.summary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-label {
  color: rgba(255, 255, 255, 0.76);
  font-size: 23rpx;
}

.summary-count {
  color: rgba(255, 255, 255, 0.64);
  font-size: 21rpx;
}

.calorie-line {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 4rpx;
}

.calorie-value {
  font-size: 54rpx;
  font-weight: 800;
}

.calorie-unit {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
}

.macro-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.16);
}

.macro-item {
  min-width: 0;
  padding: 0 16rpx;
  border-right: 1rpx solid rgba(255, 255, 255, 0.16);
  text-align: center;
}

.macro-item:first-child {
  padding-left: 0;
}

.macro-item:last-child {
  padding-right: 0;
  border-right: 0;
}

.macro-value,
.macro-label {
  display: block;
}

.macro-value {
  font-size: 27rpx;
  font-weight: 700;
}

.macro-label {
  margin-top: 5rpx;
  color: rgba(255, 255, 255, 0.66);
  font-size: 20rpx;
}

.meal-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.meal-card {
  overflow: hidden;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-card);
}

.meal-head {
  display: flex;
  min-height: 92rpx;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 22rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.meal-heading {
  flex: 1;
  min-width: 0;
}

.meal-title,
.meal-summary {
  display: block;
}

.meal-title {
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: 700;
}

.meal-summary {
  margin-top: 4rpx;
  color: var(--color-muted);
  font-size: 21rpx;
  white-space: nowrap;
}

.meal-actions {
  display: flex;
  flex: none;
  align-items: center;
  gap: 10rpx;
}

.template-button,
.add-button,
.delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.template-button {
  width: 112rpx;
  height: 58rpx;
  color: var(--color-primary-dark);
  font-size: 22rpx;
  font-weight: 600;
}

.add-button {
  width: 94rpx;
  height: 58rpx;
  border-radius: var(--radius-sm);
  background: var(--color-primary);
  color: var(--color-on-primary);
  font-size: 23rpx;
  font-weight: 700;
}

.add-button-hover {
  background: var(--color-primary-dark);
}

.meal-empty {
  display: flex;
  min-height: 112rpx;
  align-items: center;
  padding: 24rpx 22rpx;
  color: var(--color-muted);
  font-size: 23rpx;
}

.record-list {
  padding: 0 22rpx;
}

.record-row {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.record-row:last-child {
  border-bottom: 0;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-title-line {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 10rpx;
}

.record-name {
  overflow: hidden;
  color: var(--color-text);
  font-size: 27rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-amount {
  flex: none;
  color: var(--color-text-secondary);
  font-size: 23rpx;
  font-weight: 600;
}

.record-calorie,
.record-desc {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-calorie {
  margin-top: 8rpx;
  color: var(--color-primary-dark);
  font-size: 23rpx;
  font-weight: 600;
}

.record-desc {
  margin-top: 4rpx;
  color: var(--color-muted);
  font-size: 21rpx;
}

.delete-button {
  flex: 0 0 76rpx;
  width: 76rpx;
  height: 56rpx;
  border-left: 1rpx solid var(--color-border);
  color: var(--color-danger);
  font-size: 22rpx;
  font-weight: 600;
}

.delete-button-hover {
  background: rgba(217, 48, 37, 0.06);
}
