.header-row{display:flex;justify-content:space-between;gap:20rpx;align-items:flex-start}.small-button{min-width:128rpx;height:64rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);font-size:24rpx;color:var(--color-text);background:#fff}.summary-card{display:grid;grid-template-columns:repeat(2,1fr);gap:20rpx}.meal-card{display:flex;flex-direction:column;gap:16rpx}.meal-head{display:flex;justify-content:space-between;align-items:center}.meal-title{font-size:32rpx;font-weight:700}.mini-empty{padding:24rpx}.record-row{display:flex;justify-content:space-between;align-items:center;gap:16rpx;padding-top:16rpx;border-top:1rpx solid var(--color-border)}.record-name{display:block;font-size:28rpx;font-weight:600}.record-desc{display:block;margin-top:8rpx;color:var(--color-muted);font-size:24rpx;line-height:1.5}.delete-button{min-width:96rpx;height:56rpx;color:var(--color-danger);font-size:24rpx}
