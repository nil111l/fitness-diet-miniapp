<view class="page diet-detail-page">
  <view class="page-head">
    <text class="title">今日饮食</text>
    <text class="page-caption">{{date}} · 记录后自动完成饮食打卡</text>
  </view>

  <view class="quick-actions">
    <view class="quick-action" role="button" aria-label="打开饮食模板" hover-class="quick-action-hover" bindtap="goTemplates">
      <text class="quick-action-title">饮食模板</text>
      <text class="quick-action-desc">快速复用常用搭配</text>
    </view>
    <view class="quick-action" role="button" aria-label="复制昨日饮食" hover-class="quick-action-hover" bindtap="copyYesterday">
      <text class="quick-action-title">复制昨日</text>
      <text class="quick-action-desc">复用昨天的全部记录</text>
    </view>
  </view>

  <view class="summary-panel">
    <view class="summary-head">
      <text class="summary-label">今日已摄入</text>
      <text class="summary-count">{{records.length}} 条记录</text>
    </view>
    <view class="calorie-line">
      <text class="calorie-value">{{summary.calorie}}</text>
      <text class="calorie-unit">kcal</text>
    </view>
    <view class="macro-grid">
      <view class="macro-item"><text class="macro-value">{{summary.protein}}g</text><text class="macro-label">蛋白质</text></view>
      <view class="macro-item"><text class="macro-value">{{summary.carb}}g</text><text class="macro-label">碳水</text></view>
      <view class="macro-item"><text class="macro-value">{{summary.fat}}g</text><text class="macro-label">脂肪</text></view>
    </view>
  </view>

  <view class="meal-list">
    <view class="meal-card" wx:for="{{meals}}" wx:key="value">
      <view class="meal-head">
        <view class="meal-heading">
          <text class="meal-title">{{item.label}}</text>
          <text class="meal-summary">{{item.records.length}} 项 · {{item.calorie}} kcal</text>
        </view>
        <view class="meal-actions">
          <view wx:if="{{item.records.length}}" class="template-button" role="button" aria-label="将{{item.label}}存为模板" hover-class="action-hover" data-meal="{{item.value}}" bindtap="saveMealTemplate">存模板</view>
          <view class="add-button" role="button" aria-label="添加{{item.label}}" hover-class="add-button-hover" data-meal="{{item.value}}" bindtap="goAdd">添加</view>
        </view>
      </view>
      <view wx:if="{{!item.records.length}}" class="meal-empty">
        <text>还没有{{item.label}}记录，可从食材库添加。</text>
      </view>
      <view wx:else class="record-list">
        <view class="record-row" wx:for="{{item.records}}" wx:key="_id" wx:for-item="record">
          <view class="record-main" data-record="{{record}}" bindtap="editRecord">
            <view class="record-title-line">
              <text class="record-name">{{record.food_name}}</text>
              <text class="record-amount">{{record.amount_g}}g</text>
            </view>
            <text class="record-calorie">{{record.calorie}} kcal</text>
            <text class="record-desc">蛋白 {{record.protein}}g · 碳水 {{record.carb}}g · 脂肪 {{record.fat}}g</text>
          </view>
          <view class="delete-button" role="button" aria-label="删除{{record.food_name}}" hover-class="delete-button-hover" data-record="{{record}}" bindtap="deleteRecord">删除</view>
        </view>
      </view>
    </view>
  </view>
</view>
