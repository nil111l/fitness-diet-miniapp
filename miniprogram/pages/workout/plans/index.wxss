.page-head{margin-bottom:20rpx}.type-scroll{width:100%;margin-bottom:24rpx;white-space:nowrap}.type-row{display:inline-flex;gap:10rpx;padding-right:28rpx}.type-chip{display:flex;height:58rpx;align-items:center;padding:0 22rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-card);color:var(--color-text-secondary);font-size:23rpx}.type-chip-active{border-color:rgba(22,160,93,.28);background:var(--color-primary-soft);color:var(--color-primary-dark);font-weight:700}.plan-list{display:flex;flex-direction:column;gap:16rpx}.plan-card{overflow:hidden;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.plan-cover{width:100%;height:220rpx;background:var(--color-primary-soft)}.plan-cover-fallback{display:flex;align-items:flex-end;justify-content:space-between;padding:26rpx;background:var(--color-primary-deep);color:var(--color-on-primary)}.fallback-type{font-size:30rpx;font-weight:800}.fallback-duration{color:rgba(255,255,255,.72);font-size:23rpx}.plan-copy{padding:22rpx}.plan-title-line{display:flex;min-width:0;align-items:center;gap:10rpx}.plan-name{overflow:hidden;color:var(--color-text);font-size:30rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.difficulty-tag{flex:none;padding:4rpx 9rpx;border-radius:var(--radius-sm);background:var(--color-primary-tint);color:var(--color-primary-dark);font-size:19rpx}.plan-intro{display:-webkit-box;overflow:hidden;margin-top:10rpx;color:var(--color-text-secondary);font-size:23rpx;line-height:1.5;-webkit-box-orient:vertical;-webkit-line-clamp:2}.plan-meta{display:flex;flex-wrap:wrap;gap:10rpx 18rpx;margin-top:16rpx;color:var(--color-muted);font-size:21rpx}.empty{margin-top:24rpx}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.empty-action{display:flex;width:180rpx;height:64rpx;align-items:center;justify-content:center;margin:22rpx auto 0;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card);color:var(--color-text);font-size:24rpx}
