.workout-head{display:flex;align-items:flex-start;justify-content:space-between;gap:18rpx}.head-copy{flex:1;min-width:0}.eyebrow{display:block;margin-bottom:8rpx;color:var(--color-primary-dark);font-size:22rpx;font-weight:700}.progress-count{flex:none;color:var(--color-primary-dark);font-size:32rpx;font-weight:800}.progress-track{height:12rpx;margin:22rpx 0 26rpx;overflow:hidden;border-radius:6rpx;background:var(--color-border)}.progress-fill{height:100%;border-radius:6rpx;background:var(--color-primary);transition:width .2s ease}.completed-panel{margin-bottom:20rpx;padding:24rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary)}.completed-title,.completed-value,.completed-desc{display:block}.completed-title{color:rgba(255,255,255,.72);font-size:23rpx}.completed-value{margin-top:8rpx;font-size:42rpx;font-weight:800}.completed-desc{margin-top:8rpx;color:rgba(255,255,255,.68);font-size:21rpx}.today-action-list{display:flex;flex-direction:column;gap:16rpx}.today-action-card{padding:22rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.today-action-completed{border-color:rgba(22,160,93,.28);background:var(--color-primary-tint)}.action-head{display:flex;min-width:0;align-items:center;gap:14rpx}.check-control{display:flex;flex:0 0 46rpx;width:46rpx;height:46rpx;align-items:center;justify-content:center;border:2rpx solid var(--color-border);border-radius:50%;background:var(--color-card);color:var(--color-on-primary);font-size:26rpx;font-weight:800}.check-control-active{border-color:var(--color-primary);background:var(--color-primary)}.action-copy{flex:1;min-width:0}.action-name,.action-plan{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.action-name{color:var(--color-text);font-size:28rpx;font-weight:700}.action-plan{margin-top:6rpx;color:var(--color-muted);font-size:21rpx}.actual-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12rpx;margin-top:20rpx}.actual-field{min-width:0}.actual-label{display:block;margin-bottom:8rpx;color:var(--color-text-secondary);font-size:21rpx}.actual-input{width:100%;height:66rpx;padding:0 16rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-card);color:var(--color-text);font-size:24rpx}.action-footer{display:flex;align-items:center;justify-content:space-between;gap:14rpx;margin-top:18rpx;padding-top:16rpx;border-top:1rpx solid var(--color-border)}.detail-link{color:var(--color-primary-dark);font-size:22rpx;font-weight:600}.rest-button{display:flex;min-width:126rpx;height:54rpx;align-items:center;justify-content:center;padding:0 14rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-card);color:var(--color-text-secondary);font-size:21rpx}.rest-button-active{border-color:rgba(22,160,93,.28);background:var(--color-primary-soft);color:var(--color-primary-dark);font-weight:700}.complete-button,.secondary-action{display:flex;width:100%;height:88rpx;align-items:center;justify-content:center;margin-top:24rpx;border-radius:var(--radius-md);font-size:28rpx;font-weight:700}.complete-button{background:var(--color-primary);color:var(--color-on-primary)}.complete-button-disabled{background:#aeb8b3}.secondary-action{border:1rpx solid var(--color-border);background:var(--color-card);color:var(--color-text)}.no-plan-empty{margin-top:100rpx}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.empty-action{display:flex;width:260rpx;height:70rpx;align-items:center;justify-content:center;margin:24rpx auto 0;border-radius:var(--radius-md);background:var(--color-primary);color:var(--color-on-primary);font-size:25rpx;font-weight:700}
