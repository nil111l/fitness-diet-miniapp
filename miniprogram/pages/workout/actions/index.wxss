.page-head{margin-bottom:22rpx}.search-row{display:flex;gap:12rpx}.search-input{flex:1;min-width:0}.search-button{display:flex;flex:0 0 108rpx;align-items:center;justify-content:center;width:108rpx;border-radius:var(--radius-md);background:var(--color-primary);color:var(--color-on-primary);font-size:25rpx;font-weight:700}.search-button-hover{background:var(--color-primary-dark)}.category-scroll{width:100%;margin:20rpx 0 24rpx;white-space:nowrap}.category-row{display:inline-flex;gap:10rpx;padding-right:28rpx}.category-chip{display:flex;height:58rpx;align-items:center;padding:0 22rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-sm);background:var(--color-card);color:var(--color-text-secondary);font-size:23rpx}.category-chip-active{border-color:rgba(22,160,93,.28);background:var(--color-primary-soft);color:var(--color-primary-dark);font-weight:700}.action-list{display:flex;flex-direction:column;gap:14rpx}.action-card{display:flex;min-width:0;align-items:center;gap:18rpx;padding:18rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.action-cover{flex:0 0 132rpx;width:132rpx;height:112rpx;border-radius:var(--radius-sm);background:var(--color-primary-soft)}.action-cover-fallback{display:flex;align-items:center;justify-content:center;color:var(--color-primary-dark);font-size:24rpx;font-weight:700}.action-copy{flex:1;min-width:0}.action-title-line{display:flex;min-width:0;align-items:center;gap:10rpx}.action-name{overflow:hidden;color:var(--color-text);font-size:28rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.difficulty-tag{flex:none;padding:4rpx 9rpx;border-radius:var(--radius-sm);background:var(--color-primary-tint);color:var(--color-primary-dark);font-size:19rpx}.action-target,.action-meta{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.action-target{margin-top:10rpx;color:var(--color-text-secondary);font-size:23rpx}.action-meta{margin-top:7rpx;color:var(--color-muted);font-size:21rpx}.action-arrow{flex:none;color:var(--color-muted);font-size:38rpx}.empty{margin-top:24rpx}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.empty-action{display:flex;width:180rpx;height:64rpx;align-items:center;justify-content:center;margin:22rpx auto 0;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card);color:var(--color-text);font-size:24rpx}
