.action-detail-page{padding-bottom:64rpx}.action-media{width:100%;height:380rpx;border-radius:var(--radius-md);background:var(--color-primary-soft)}.media-fallback{display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--color-primary-deep);color:var(--color-on-primary)}.media-category{color:rgba(255,255,255,.68);font-size:24rpx}.media-name{margin-top:12rpx;font-size:38rpx;font-weight:800}.detail-head{padding:26rpx 0}.tag-line{display:flex;gap:10rpx;margin-bottom:14rpx}.tag{padding:6rpx 12rpx;border-radius:var(--radius-sm);background:var(--color-primary-soft);color:var(--color-primary-dark);font-size:21rpx;font-weight:700}.fact-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.fact-item{min-width:0;padding:22rpx 14rpx;border-right:1rpx solid var(--color-border);text-align:center}.fact-item:last-child{border-right:0}.fact-label,.fact-value{display:block}.fact-label{color:var(--color-muted);font-size:20rpx}.fact-value{overflow:hidden;margin-top:8rpx;color:var(--color-text);font-size:23rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.detail-section{padding:32rpx 0;border-bottom:1rpx solid var(--color-border)}.number-row,.bullet-row{display:flex;gap:14rpx;margin-top:20rpx}.number{display:flex;flex:0 0 42rpx;width:42rpx;height:42rpx;align-items:center;justify-content:center;border-radius:50%;background:var(--color-primary-soft);color:var(--color-primary-dark);font-size:21rpx;font-weight:800}.row-text{flex:1;min-width:0;color:var(--color-text-secondary);font-size:26rpx;line-height:1.65}.bullet{flex:0 0 10rpx;width:10rpx;height:10rpx;margin-top:16rpx;border-radius:50%;background:var(--color-danger)}.notice-section{border-bottom:0}.notice-bullet{background:var(--color-warning)}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}
