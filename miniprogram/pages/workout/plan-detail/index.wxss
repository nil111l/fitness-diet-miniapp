.plan-detail-page{padding-bottom:64rpx}.plan-hero{width:100%;height:320rpx;border-radius:var(--radius-md);background:var(--color-primary-soft)}.hero-fallback{display:flex;flex-direction:column;justify-content:flex-end;padding:28rpx;background:var(--color-primary-deep);color:var(--color-on-primary)}.hero-type{color:rgba(255,255,255,.68);font-size:23rpx}.hero-name{margin-top:10rpx;font-size:38rpx;font-weight:800}.detail-head{padding:26rpx 0}.tag-line{display:flex;flex-wrap:wrap;gap:10rpx;margin-bottom:14rpx}.tag{padding:6rpx 12rpx;border-radius:var(--radius-sm);background:var(--color-primary-soft);color:var(--color-primary-dark);font-size:21rpx;font-weight:700}.current-tag{background:var(--color-primary);color:var(--color-on-primary)}.goal-panel{padding:24rpx;border-radius:var(--radius-md);background:var(--color-primary-tint)}.goal-label,.goal-value{display:block}.goal-label{color:var(--color-primary-dark);font-size:22rpx;font-weight:700}.goal-value{margin-top:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.metric-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));margin-top:18rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.metric-item{min-width:0;padding:22rpx 8rpx;border-right:1rpx solid var(--color-border);text-align:center}.metric-item:last-child{border-right:0}.metric-value-small,.metric-label{display:block}.metric-value-small{color:var(--color-text);font-size:30rpx;font-weight:800}.metric-label{margin-top:6rpx;color:var(--color-muted);font-size:19rpx}.action-section{padding:32rpx 0}.plan-action-row{display:flex;min-width:0;align-items:center;gap:14rpx;padding:20rpx 0;border-bottom:1rpx solid var(--color-border)}.action-index{display:flex;flex:0 0 42rpx;width:42rpx;height:42rpx;align-items:center;justify-content:center;border-radius:50%;background:var(--color-primary-soft);color:var(--color-primary-dark);font-size:20rpx;font-weight:800}.action-copy{flex:1;min-width:0}.action-name,.action-meta{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.action-name{color:var(--color-text);font-size:27rpx;font-weight:700}.action-meta{margin-top:7rpx;color:var(--color-muted);font-size:21rpx}.arrow{flex:none;color:var(--color-muted);font-size:36rpx}.primary-action{display:flex;width:100%;height:88rpx;align-items:center;justify-content:center;border-radius:var(--radius-md);background:var(--color-primary);color:var(--color-on-primary);font-size:28rpx;font-weight:700}.primary-action-hover{background:var(--color-primary-dark)}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}
