<view class="page plan-detail-page" wx:if="{{plan}}">
  <image wx:if="{{plan.cover_url}}" class="plan-hero" mode="aspectFill" src="{{plan.cover_url}}" />
  <view wx:else class="plan-hero hero-fallback"><text class="hero-type">{{plan.plan_type_text}}</text><text class="hero-name">{{plan.name}}</text></view>

  <view class="detail-head">
    <view class="tag-line"><text class="tag">{{plan.plan_type_text}}</text><text class="tag">{{plan.difficulty_text}}</text><text wx:if="{{plan.is_current}}" class="tag current-tag">当前计划</text></view>
    <text class="title">{{plan.name}}</text>
    <text class="subtitle">{{plan.intro}}</text>
  </view>

  <view class="goal-panel"><text class="goal-label">计划目标</text><text class="goal-value">{{plan.goal}}</text></view>
  <view class="metric-grid">
    <view class="metric-item"><text class="metric-value-small">{{plan.duration_weeks}}</text><text class="metric-label">周期（周）</text></view>
    <view class="metric-item"><text class="metric-value-small">{{plan.weekly_frequency}}</text><text class="metric-label">每周次数</text></view>
    <view class="metric-item"><text class="metric-value-small">{{plan.session_duration_min}}</text><text class="metric-label">单次分钟</text></view>
    <view class="metric-item"><text class="metric-value-small">{{plan.action_count}}</text><text class="metric-label">动作数</text></view>
  </view>

  <view class="action-section">
    <text class="section-title">训练动作</text>
    <view class="plan-action-row" wx:for="{{plan.actions}}" wx:key="action_id" role="button" data-id="{{item.action_id}}" bindtap="openAction">
      <text class="action-index">{{index + 1}}</text>
      <view class="action-copy"><text class="action-name">{{item.action.name}}</text><text class="action-meta">{{item.sets}} 组 · {{item.reps}} · 休息 {{item.rest_text}}</text></view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view wx:if="{{plan.is_current}}" class="primary-action" role="button" hover-class="primary-action-hover" bindtap="startToday">进入今日训练</view>
  <view wx:else class="primary-action" role="button" hover-class="primary-action-hover" bindtap="selectPlan">{{selecting ? '正在保存...' : '设为当前计划'}}</view>
</view>
<view class="loading-state" wx:elif="{{loading}}">正在加载计划...</view>
<view class="page" wx:else><view class="card empty"><text class="empty-title">计划暂时无法打开</text><text class="muted-text">计划可能已下架或动作内容已调整。</text></view></view>
