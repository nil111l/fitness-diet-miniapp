.calendar-page{padding-bottom:56rpx}.streak-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16rpx}.streak-card{padding:28rpx;border:1rpx solid rgba(22,160,93,.16);border-radius:var(--radius-lg);background:var(--color-card)}.streak-label{display:block;color:var(--color-muted);font-size:24rpx}.streak-value{display:block;margin-top:8rpx;color:var(--color-primary-dark);font-size:38rpx;font-weight:800}.calendar-card{padding:24rpx}.month-nav{display:flex;align-items:center;justify-content:space-between;gap:16rpx;min-height:64rpx}.month-button{display:flex;flex:0 0 64rpx;align-items:center;justify-content:center;width:64rpx;min-width:64rpx;max-width:64rpx;height:64rpx;margin:0;border:1rpx solid var(--color-border);border-radius:50%;background:var(--color-card);color:var(--color-text)}.month-button-pressed{background:var(--color-primary-soft)}.month-button.disabled{opacity:.45}.month-arrow{font-size:40rpx;line-height:1}.month-title{flex:1;min-width:0;text-align:center;font-size:30rpx;font-weight:700}.weekday-row,.calendar-grid{display:grid;grid-template-columns:repeat(7,1fr)}.weekday{padding:24rpx 0 16rpx;color:var(--color-muted);font-size:22rpx;text-align:center}.day-cell{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:92rpx;border-radius:12rpx}.day-cell.today{background:rgba(22,160,93,.09)}.day-cell.future{opacity:.38}.day-number{font-size:24rpx}.day-dots{display:flex;justify-content:center;gap:5rpx;min-height:10rpx;margin-top:9rpx}.dot{display:block;width:9rpx;height:9rpx;border-radius:50%}.dot.diet{background:var(--color-primary)}.dot.exercise{background:var(--color-accent-blue)}.dot.weight{background:var(--color-warning)}.legend{display:flex;justify-content:center;gap:28rpx;margin-top:24rpx;padding-top:22rpx;border-top:1rpx solid var(--color-border)}.legend-item{display:flex;align-items:center;gap:8rpx;color:var(--color-muted);font-size:22rpx}
