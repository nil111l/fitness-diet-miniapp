.warning-card {
  padding: 34rpx;
  border-radius: 28rpx;
  background: #2b201d;
  color: #ffffff;
}

.warning-title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
}

.warning-desc {
  display: block;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 26rpx;
  line-height: 1.7;
}

.rule-card {
  margin-top: 24rpx;
  border: 0;
  border-radius: 24rpx;
}

.rule-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.rule-item {
  display: block;
  margin-top: 12rpx;
  color: #6f7d76;
  font-size: 26rpx;
  line-height: 1.5;
}

.confirm-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 32rpx 0;
  color: #1f2d26;
  font-size: 26rpx;
}

.check-box {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  border: 2rpx solid #9eb0a7;
}

.check-box.checked {
  background: #d93025;
  border-color: #d93025;
}

.delete-submit {
  width: 100%;
  min-height: 88rpx;
  background: #d93025;
  color: #ffffff;
}
