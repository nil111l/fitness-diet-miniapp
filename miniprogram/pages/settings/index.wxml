<view class="page settings-page">
  <view class="card status-card">
    <text class="section-title">登录状态</text>
    <text class="status-text">{{user ? '已登录' : '未登录'}}</text>
    <text class="subtitle">{{user ? user.nick_name || '健康用户' : '登录后可同步健康档案、饮食、运动和体重记录'}}</text>
  </view>

  <view class="section action-list">
    <button wx:if="{{user}}" class="secondary-button" bindtap="goReminders">记录提醒设置</button>
    <button wx:if="{{!user}}" class="primary-button" bindtap="goLogin">微信登录</button>
    <button wx:else class="secondary-button" bindtap="logout">退出登录</button>
    <button wx:if="{{user}}" class="danger-button delete-button" bindtap="goDeleteAccount">进入注销账号页</button>
  </view>
</view>
