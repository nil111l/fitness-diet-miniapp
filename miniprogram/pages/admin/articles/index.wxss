.search-row{display:flex;gap:12rpx}.search-input{flex:1;min-width:0}.search-button{display:flex;flex:0 0 108rpx;align-items:center;justify-content:center;border-radius:var(--radius-md);background:var(--color-primary);color:var(--color-on-primary);font-size:24rpx;font-weight:700}.create-button{display:flex;width:100%;height:78rpx;align-items:center;justify-content:center;margin:16rpx 0 22rpx;border-radius:var(--radius-md);background:var(--color-primary-deep);color:var(--color-on-primary);font-size:26rpx;font-weight:700}.article-list{display:flex;flex-direction:column;gap:14rpx}.article-card{padding:22rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.card-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16rpx}.title-wrap{display:flex;min-width:0;align-items:center;gap:10rpx}.article-title{overflow:hidden;color:var(--color-text);font-size:28rpx;font-weight:700;text-overflow:ellipsis;white-space:nowrap}.recommend{flex:none;padding:3rpx 8rpx;border-radius:var(--radius-sm);background:var(--color-primary-soft);color:var(--color-primary-dark);font-size:19rpx}.status{flex:none;color:var(--color-muted);font-size:21rpx}.status-active{color:var(--color-primary-dark)}.article-meta{display:block;margin-top:10rpx;color:var(--color-primary-dark);font-size:21rpx}.article-summary{display:block;margin-top:10rpx;color:var(--color-muted);font-size:23rpx;line-height:1.5}.action-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8rpx;margin-top:18rpx;padding-top:16rpx;border-top:1rpx solid var(--color-border)}.row-button{display:flex;height:58rpx;align-items:center;justify-content:center;color:var(--color-text);font-size:22rpx}.danger-text{color:var(--color-danger)}.primary-text{color:var(--color-primary-dark)}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry-button{width:220rpx;margin:24rpx auto 0}
