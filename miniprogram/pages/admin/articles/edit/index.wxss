.short-textarea{min-height:130rpx}.body-textarea{min-height:360rpx}.switch-row{display:flex;align-items:center;justify-content:space-between;gap:20rpx;padding-top:6rpx}.save-button{display:flex;width:100%;height:88rpx;align-items:center;justify-content:center;border-radius:var(--radius-md);background:var(--color-primary);color:var(--color-on-primary);font-size:28rpx;font-weight:700}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{display:flex;width:220rpx;margin:24rpx auto 0;align-items:center;justify-content:center}
