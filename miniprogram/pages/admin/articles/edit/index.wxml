<view class="page" wx:if="{{!loading && !loadFailed}}"><view class="section"><text class="title">{{articleId ? '编辑文章' : '新增文章'}}</text><text class="subtitle">文章上架后用户端可见，推荐文章会展示在首页。</text></view><view class="section card form-card"><view class="field"><text class="label">文章标题 *</text><input class="input" maxlength="60" value="{{form.title}}" data-field="title" bindinput="inputField"/></view><view class="field"><text class="label">文章摘要 *</text><textarea class="textarea short-textarea" maxlength="180" value="{{form.summary}}" data-field="summary" bindinput="inputField"></textarea></view><view class="field"><text class="label">文章类型 *</text><picker range="{{categories}}" range-key="label" value="{{categoryIndex}}" bindchange="changeCategory"><view class="picker-value">{{categories[categoryIndex].label}}</view></picker></view><view class="field"><text class="label">封面地址</text><input class="input" value="{{form.cover_url}}" placeholder="https:// 或 cloud://" data-field="cover_url" bindinput="inputField"/></view><view class="field"><text class="label">正文 *</text><textarea class="textarea body-textarea" maxlength="12000" value="{{form.content_text}}" placeholder="每段之间换行" data-field="content_text" bindinput="inputField"></textarea></view><view class="field"><text class="label">排序</text><input class="input" type="number" value="{{form.sort_order}}" data-field="sort_order" bindinput="inputField"/></view><view class="switch-row"><view><text class="label">上架状态</text><text class="muted-text">关闭后用户端不可见。</text></view><switch checked="{{form.status === 'active'}}" color="#16a05d" bindchange="toggleStatus"/></view><view class="switch-row"><view><text class="label">首页推荐</text><text class="muted-text">仅已上架文章会在首页展示。</text></view><switch checked="{{form.is_recommended}}" color="#16a05d" bindchange="toggleRecommended"/></view></view><view class="save-button" role="button" bindtap="saveArticle">{{saving ? '正在保存...' : '保存文章'}}</view></view><view class="page" wx:elif="{{loadFailed}}"><view class="card empty"><text class="empty-title">文章加载失败</text><text class="muted-text">为避免覆盖原内容，请重新加载。</text><view class="secondary-button retry" role="button" bindtap="loadPage">重新加载</view></view></view><view class="loading-state" wx:else>正在加载文章...</view>
