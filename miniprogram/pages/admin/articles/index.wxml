<view class="page"><view class="section"><text class="title">文章管理</text><text class="subtitle">维护健康文章、展示状态和首页推荐。</text></view><view class="search-row"><input class="input search-input" value="{{keyword}}" placeholder="搜索文章标题" bindinput="inputKeyword" confirm-type="search" bindconfirm="loadArticles"/><view class="search-button" role="button" bindtap="loadArticles">搜索</view></view><view class="create-button" role="button" bindtap="createArticle">新增文章</view><view class="article-list" wx:if="{{articles.length}}"><view class="article-card" wx:for="{{articles}}" wx:key="_id"><view class="card-head"><view class="title-wrap"><text class="article-title">{{item.title}}</text><text wx:if="{{item.is_recommended}}" class="recommend">推荐</text></view><text class="status {{item.status === 'active' ? 'status-active' : ''}}">{{item.status === 'active' ? '已上架' : '已下架'}}</text></view><text class="article-meta">{{item.category_text}} · 排序 {{item.sort_order}}</text><text class="article-summary">{{item.summary}}</text><view class="action-row"><view class="row-button" role="button" data-id="{{item._id}}" bindtap="editArticle">编辑</view><view class="row-button primary-text" role="button" data-item="{{item}}" bindtap="toggleRecommended">{{item.is_recommended ? '取消推荐' : '设为推荐'}}</view><view class="row-button {{item.status === 'active' ? 'danger-text' : 'primary-text'}}" role="button" data-item="{{item}}" bindtap="toggleStatus">{{item.status === 'active' ? '下架' : '上架'}}</view></view></view></view><view class="card empty" wx:elif="{{!loading}}"><text class="empty-title">{{loadFailed ? '文章列表加载失败' : '暂无文章'}}</text><text class="muted-text">{{loadFailed ? '请检查网络后重新加载。' : '点击上方按钮新增第一篇内容。'}}</text><view wx:if="{{loadFailed}}" class="secondary-button retry-button" role="button" bindtap="loadArticles">重新加载</view></view><view class="loading-state" wx:if="{{loading}}">正在加载...</view></view>
