.summary-head{display:flex;align-items:flex-start;justify-content:space-between;gap:18rpx}.food-name{display:block;color:var(--color-text);font-size:30rpx;font-weight:700}.status{flex:none;color:var(--color-muted);font-size:21rpx}.status-resolved{color:var(--color-primary-dark)}.status-processing{color:var(--color-accent-blue)}.status-rejected{color:var(--color-danger)}.description{display:block;margin-top:18rpx;color:var(--color-text-secondary);font-size:25rpx;line-height:1.6}.suggested{display:block;margin-top:10rpx;color:var(--color-primary-dark);font-size:23rpx}.applied-note{display:block;margin-top:14rpx;padding:12rpx;border-radius:var(--radius-sm);background:var(--color-primary-soft);color:var(--color-primary-dark);font-size:22rpx}.snapshot{padding:24rpx;border-radius:var(--radius-md);background:var(--color-primary-tint)}.snapshot-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12rpx;margin-top:16rpx;color:var(--color-text-secondary);font-size:23rpx}.switch-row{display:flex;align-items:center;justify-content:space-between;gap:20rpx}.nutrition-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14rpx}.save-button{display:flex;width:100%;height:88rpx;align-items:center;justify-content:center;border-radius:var(--radius-md);background:var(--color-primary);color:var(--color-on-primary);font-size:28rpx;font-weight:700}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry{display:flex;width:220rpx;margin:24rpx auto 0;align-items:center;justify-content:center}
