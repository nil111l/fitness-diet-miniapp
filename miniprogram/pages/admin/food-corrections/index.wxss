.correction-list{display:flex;flex-direction:column;gap:14rpx}.correction-card{padding:22rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.card-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16rpx}.food-name,.type-text{display:block}.food-name{color:var(--color-text);font-size:29rpx;font-weight:700}.type-text{margin-top:5rpx;color:var(--color-muted);font-size:21rpx}.status{flex:none;color:var(--color-muted);font-size:21rpx}.status-resolved{color:var(--color-primary-dark)}.status-processing{color:var(--color-accent-blue)}.status-rejected{color:var(--color-danger)}.description{display:-webkit-box;overflow:hidden;margin-top:16rpx;color:var(--color-text-secondary);font-size:24rpx;line-height:1.55;-webkit-box-orient:vertical;-webkit-line-clamp:2}.card-foot{display:flex;align-items:center;justify-content:space-between;margin-top:16rpx;padding-top:14rpx;border-top:1rpx solid var(--color-border);color:var(--color-muted);font-size:21rpx}.arrow{font-size:34rpx}.empty-title{display:block;margin-bottom:8rpx;color:var(--color-text);font-size:28rpx;font-weight:700}.retry-button{width:220rpx;margin:24rpx auto 0}
