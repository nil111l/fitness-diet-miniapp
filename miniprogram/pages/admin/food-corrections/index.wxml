<view class="page"><view class="section"><text class="title">食材纠错管理</text><text class="subtitle">核对用户提交的问题，并在确认后更新平台食材。</text></view><picker class="section" range="{{statuses}}" range-key="label" value="{{statusIndex}}" bindchange="changeStatus"><view class="picker-value">{{statuses[statusIndex].label}}</view></picker><view class="correction-list" wx:if="{{records.length}}"><view class="correction-card" wx:for="{{records}}" wx:key="_id" role="button" data-id="{{item._id}}" bindtap="openDetail"><view class="card-head"><view><text class="food-name">{{item.food_name}}</text><text class="type-text">{{item.correction_type_text}}</text></view><text class="status status-{{item.status}}">{{item.status_text}}</text></view><text class="description">{{item.description}}</text><view class="card-foot"><text>{{item.applied_food_update ? '已同步修改食材' : '未修改食材'}}</text><text class="arrow">›</text></view></view></view><view class="card empty" wx:elif="{{!loading}}"><text class="empty-title">{{loadFailed ? '纠错列表加载失败' : '当前状态下暂无食材纠错'}}</text><text class="muted-text" wx:if="{{loadFailed}}">请检查网络后重新加载。</text><view wx:if="{{loadFailed}}" class="secondary-button retry-button" role="button" bindtap="loadRecords">重新加载</view></view><view class="loading-state" wx:if="{{loading}}">正在加载...</view></view>
