.form-actions{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12rpx}.form-actions .primary-button:only-child{grid-column:1/-1}.tag-list{display:flex;flex-direction:column;gap:14rpx;margin-top:24rpx}.tag-row{display:flex;align-items:center;justify-content:space-between;gap:16rpx;padding:22rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.tag-actions{display:flex;gap:8rpx}.tag-actions button{min-height:58rpx;padding:0 12rpx;font-size:20rpx}
