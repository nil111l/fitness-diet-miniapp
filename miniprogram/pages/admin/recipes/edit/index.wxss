.editor-head{margin-bottom:28rpx}.editor-section{display:flex;flex-direction:column;gap:20rpx;padding:28rpx 0;border-bottom:1rpx solid var(--color-border)}.editor-section>.section-title{margin-bottom:2rpx}.section-heading{display:flex;align-items:center;justify-content:space-between;gap:16rpx}.choice-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12rpx}.choice-item{display:flex;align-items:center;min-height:66rpx;padding:0 14rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card);font-size:25rpx}.choice-item checkbox{transform:scale(.8);transform-origin:left center}.ingredient-editor{display:grid;grid-template-columns:minmax(0,1fr) 150rpx 76rpx;align-items:center;gap:10rpx}.amount-wrap{display:grid;grid-template-columns:minmax(0,1fr) 24rpx;align-items:center;gap:4rpx;color:var(--color-muted);font-size:23rpx}.amount-input{padding-left:12rpx;padding-right:8rpx}.remove-icon{display:flex;align-items:center;justify-content:center;min-height:64rpx;color:var(--color-danger);font-size:22rpx}.empty-inline{padding:24rpx;border:1rpx dashed var(--color-border);border-radius:var(--radius-md);color:var(--color-muted);font-size:24rpx;text-align:center}.step-editor{display:grid;grid-template-columns:44rpx minmax(0,1fr) 76rpx;align-items:flex-start;gap:10rpx}.step-index{display:flex;align-items:center;justify-content:center;width:40rpx;height:40rpx;margin-top:14rpx;border-radius:50%;background:var(--color-success-soft);color:var(--color-primary-dark);font-size:21rpx;font-weight:800}.step-input{min-height:126rpx}.status-section{gap:0}.switch-row{display:flex;align-items:center;justify-content:space-between;min-height:108rpx;border-bottom:1rpx solid var(--color-border)}.switch-row:last-child{border-bottom:0}.save-button{margin-top:28rpx}
