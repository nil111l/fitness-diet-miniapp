.admin-head{display:flex;align-items:flex-start;justify-content:space-between;gap:18rpx}.tag-button{flex:none}.search-row{display:grid;grid-template-columns:minmax(0,1fr) 120rpx;gap:12rpx;margin-top:24rpx}.search-button{width:120rpx}.create-button{margin:18rpx 0 24rpx}.recipe-list{display:flex;flex-direction:column;gap:16rpx}.admin-recipe-card{padding:24rpx;border:1rpx solid var(--color-border);border-radius:var(--radius-md);background:var(--color-card)}.card-top{display:flex;align-items:center;justify-content:space-between;gap:16rpx;margin-bottom:10rpx}.card-title-wrap{display:flex;align-items:center;min-width:0;gap:10rpx}.card-title-wrap .list-title{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.recommend-mark{padding:4rpx 9rpx;border-radius:var(--radius-sm);background:var(--color-success-soft);color:var(--color-primary-dark);font-size:19rpx}.status-text{flex:none;color:var(--color-muted);font-size:22rpx}.status-active{color:var(--color-primary-dark)}.scope-text{display:block;margin-top:8rpx;color:var(--color-text-secondary);font-size:22rpx}.action-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10rpx;margin-top:18rpx}.action-row button{width:100%;padding:0 8rpx;font-size:21rpx}
